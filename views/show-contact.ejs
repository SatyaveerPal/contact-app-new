<%- include("header") -%>

    <div class="container">
        <h2 class="mt-4 bg-primary text-white p-3 top-heading">View Contact</h2>
    <table class="table table-dark table-hover">
        <tr>
            <th>First Name</th>
            <td><%= contact.firstName %></td>
        </tr>
        <tr>
            <th>Last Name</th>
            <td><%= contact.lastName %></td>
        </tr>
        <tr>
            <th>Email</th>
            <td><%= contact.email %></td>
        </tr>
        <tr>
            <th>Phone</th>
            <td><%= contact.phone %></td>
        </tr>

        <tr>
            <th>Address</th>
            <td>
                <%= contact.address %>
            </td>
        </tr>


     </table>
    </div>


    <%- include("footer") -%>